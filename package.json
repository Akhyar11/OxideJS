{
  "name": "ml-v2",
  "version": "1.1.0",
  "napi": {
    "name": "ml-native"
  },
  "main": "index.js",
  "scripts": {
    "test": "npx ts-node test/test.ts",
    "test:mha-rust": "npx ts-node test/mha_rust_regression.ts",
    "test:mha-rust:perf": "npx ts-node test/mha_rust_perf.ts",
    "test:perf": "npx ts-node test/perf_math.ts",
    "test:math-bot": "npx ts-node test/math_bot_dataset.ts",
    "train:math-bot": "npx ts-node project/math-bot/main.ts",
    "chat:math-bot": "npx ts-node project/math-bot/chat.ts",
    "start": "clear && tsc && time node build/main.js",
    "build:rust": "napi build --platform --release --cargo-cwd src-rust && mv *.node ml-native.node",
    "build:rust:debug": "napi build --platform --cargo-cwd src-rust && mv *.node ml-native.node"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@types/node": "^20.11.20"
  },
  "dependencies": {
    "ts-node": "^10.9.2",
    "@napi-rs/wasm-runtime": "^0.2.4"
  }
}
