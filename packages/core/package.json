{
  "name": "@oxide-js/core",
  "version": "0.3.0",
  "type": "module",
  "description": "Oxide-JS Core: Matrix operations and Rust native acceleration.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akhyar11/Oxide-JS.git",
    "directory": "packages/core"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
