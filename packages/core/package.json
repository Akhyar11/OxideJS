    "napi",
    "oxide-js"
  ],
  "author": "Akhyar",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@napi-rs/wasm-runtime": "^0.2.4"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}