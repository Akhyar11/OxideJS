{
  "name": "@oxide-js/layers",
  "version": "1.0.0",
  "type": "module",
  "description": "Oxide-JS Layers: Neural network layer abstractions.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akhyar11/Oxide-JS.git",
    "directory": "packages/layers"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "napi": {
    "name": "layers-native"
  },
  "scripts": {
    "build": "tsc",
    "build:rust": "napi build --platform --release --cargo-cwd src-rust",
    "postinstall": "node -e \"try{require('child_process').execSync('npm run build:rust',{stdio:'inherit'})}catch(e){console.warn('[oxide-js] Layers Rust native build skipped — native acceleration unavailable.')}\""
  },
  "keywords": [
    "neural-networks",
    "layer",
    "oxide-js"
  ],
  "author": "Akhyar",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oxide-js/core": "*",
    "@napi-rs/cli": "^2.18.0",
    "@napi-rs/wasm-runtime": "^0.2.4"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
